{
    "build_path": "dist/lpack",
    "description": "lpack is a lightweight Linux package manager built for portable, distro-independent .lpk packages.",

    "package": {
        "name": "lpack",
        "package": "bytesketch.lpack",
        "version": "1.0-prototype",
        "authors": ["Ali Ahmad @bytesketch"]
    },

    "app": {
        "binary": "lpack",
        "entry": "lpack"
    },

    "include": {
        "LICENSE": "docs/LICENSE",
        "README.md": "docs/README.md"
    }
}
